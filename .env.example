# Postgres connection strings used by Prisma.
# Run `npx prisma dev` to start a local Prisma Postgres instance and print both values.
# DATABASE_URL is the proxy URL used by the Prisma CLI (migrate/generate).
# DIRECT_DATABASE_URL is the raw Postgres TCP URL used by the app at runtime (via @prisma/adapter-pg).
DATABASE_URL=
DIRECT_DATABASE_URL=

# Port the HTTP server listens on
PORT=3000

# development | production | test
NODE_ENV=development
