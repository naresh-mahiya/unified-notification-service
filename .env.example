# Postgres connection string used by both the Prisma CLI and the app itself.
#
# Docker Compose (recommended — see README "Local Setup"): the `postgres` service
# exposes port 5432 on the host with these exact credentials, so this default works
# as-is for running the app natively (npm run dev) against the dockerized database:
DATABASE_URL="postgres://postgres:postgres@localhost:5432/notification_service"

# Optional — leave unset and notifications dispatch synchronously (no queue), which
# is the default for native/host runs. Uncomment to enable async, queue-based
# dispatch instead (see "Scalability & Reliability" in the README); this value
# matches the Docker Compose `redis` service's exposed host port. Requires
# `docker compose up -d redis` (or the full stack) to actually be running.
# REDIS_URL="redis://localhost:6379"

# Port the HTTP server listens on
PORT=3000

# development | production | test
NODE_ENV=development
